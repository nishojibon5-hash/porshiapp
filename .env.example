# Porshi - Environment Variables Template
# Copy this file to .env and fill in your values

# Frontend Configuration
VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME=Porshi
VITE_APP_VERSION=1.0.0

# GitHub Actions (add to GitHub Secrets, not here)
# GITHUB_TOKEN=xxx
# VERCEL_TOKEN=xxx
# VERCEL_ORG_ID=xxx
# VERCEL_PROJECT_ID=xxx

# Vercel Backend Configuration
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/porshi
APP_URL=https://your-deployment.vercel.app
ENCRYPTION_KEY=your-32-character-encryption-key-here
FCM_SERVER_KEY=your-firebase-cloud-messaging-key-here

# Firebase Configuration (for push notifications)
FIREBASE_API_KEY=xxx
FIREBASE_AUTH_DOMAIN=xxx.firebaseapp.com
FIREBASE_PROJECT_ID=xxx
FIREBASE_STORAGE_BUCKET=xxx.appspot.com
FIREBASE_MESSAGING_SENDER_ID=xxx
FIREBASE_APP_ID=xxx

# Development Settings
DEBUG=porshi:*
LOG_LEVEL=debug
MOCK_DEVICES=true
